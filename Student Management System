import java.util.*;
public class Student {
    int studentId;
    String name;
    int age;
    String course;
    double marks;
    void inputDetails(Scanner sc) {
        System.out.print("ID: ");
        studentId = sc.nextInt(); sc.nextLine();
        System.out.print("Name: ");
        name = sc.nextLine();
        System.out.print("Age: ");
        age = sc.nextInt(); sc.nextLine();
        System.out.print("Course: ");
        course = sc.nextLine();
        System.out.print("Marks: ");
        marks = sc.nextDouble();
    }
    void displayDetails() {
        System.out.println(studentId + " " + name + " " + age + " " + course + " " + marks);
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Student> list = new ArrayList<>();
        int choice;
        do {
           System.out.println("\n1.Add");
           System.out.println("\n2.Display");
           System.out.println("\n3.Search");
           System.out.println("\n4. Above Marks");
           System.out.println("\n5.Average");
           System.out.println("\n6.Sort");
           System.out.println("\n7.Update");
           System.out.println("\n8.Delete Student");
           System.out.println("\n9.Exit");
            choice = sc.nextInt();
            switch (choice) {
                case 1:
                    Student s = new Student();
                    s.inputDetails(sc);
                    list.add(s);
                    break;
                case 2:
                    for (Student st : list)
                        st.displayDetails();
                    break;
                case 3:
                    System.out.print("Enter ID: ");
                    int id = sc.nextInt();
                    for (Student st : list)
                        if (st.studentId == id)
                            st.displayDetails();
                    break;
                case 4:
                    System.out.print("Enter Marks: ");
                    double m = sc.nextDouble();
                    for (Student st : list)
                        if (st.marks > m)
                            st.displayDetails();
                    break;
                case 5:
                    double sum = 0;
                    for (Student st : list)
                        sum += st.marks;
                    System.out.println("Average = " + (list.size() > 0 ? sum / list.size() : 0));
                    break;
                case 6:
                    list.sort((a, b) -> Double.compare(a.marks, b.marks));
                    System.out.println("Sorted by marks");
                    break;
                case 7:
                    System.out.print("Enter ID to update: ");
                    int uid = sc.nextInt();
                    for (Student st : list)
                        if (st.studentId == uid)
                            st.inputDetails(sc);
                    break;
                case 8:
                    System.out.print("Enter ID to delete: ");
                    int did = sc.nextInt();
                    list.removeIf(st -> st.studentId == did);
                    break;
            }
        } while (choice != 9);
    }
}
